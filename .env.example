# --- TELEGRAM ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
OWNER_ID=your_telegram_id_here

# --- DATABASE (SUPABASE) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# --- AI PROVIDERS (At least one required) ---
GROQ_KEYS=key1,key2
CEREBRAS_KEYS=key1,key2
OPENROUTER_KEYS=key1,key2
GEMINI_KEYS=your_gemini_key1,your_gemini_key2

# --- DEPLOYMENT ---
PUBLIC_URL=https://your-app-name.onrender.com
PORT=3000

# --- DASHBOARD ---
DASHBOARD_SECRET=your_dashboard_secret_here

# --- TELEGRAM CHANNEL (Optional) ---
TELEGRAM_CHANNEL_ID=@your_channel_username

# --- SCRAPER ---
# COOKIES (Optional for Uzum/OLX if needed)
UZUM_COOKIES=""
OLX_COOKIES=""

# --- REDIS (Optional) ---
REDIS_URL=redis://localhost:6379

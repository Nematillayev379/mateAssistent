# =========================================
# Uzbekistan Newsroom Bot — Environment Vars
# =========================================

# 🤖 Telegram Bot Configuration (REQUIRED)
TELEGRAM_TOKEN=your_telegram_bot_token_here
OWNER_ID=8566566223
DASHBOARD_SECRET=your_long_random_secret_here
TELEGRAM_CHANNEL_ID=@your_channel_or_-100xxxx

# 🗄️ Supabase Configuration (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# 🧠 AI Keys — at least ONE set is required (20+ keys supported)
# Format: comma-separated OR one key per line (Render Secret File)
# Also works: GROQ_KEY_1, GROQ_KEY_2, GEMINI_KEY_1, ...
GROQ_KEYS=gsk_key1
gsk_key2
GEMINI_KEYS=AIzaKey1
AIzaKey2
CEREBRAS_KEYS=csk-key1
OPENROUTER_KEYS=sk-or-key1
OPENAI_API_KEY=sk-openai-single-key

# 🌐 Deployment (REQUIRED for webhook mode on Render)
PUBLIC_URL=https://your-app-name.onrender.com
PORT=3000

# 📦 Redis / BullMQ (optional — leave empty to use inline processing)
REDIS_URL=

# 💰 Payments (optional — Stripe keyinroq qo'shiladi)
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_KEY=your_payme_merchant_key
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=

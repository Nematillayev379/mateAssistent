{
  "name": "uzbekistan-newsroom-bot",
  "version": "2.0.0",
  "private": true,
  "description": "Uzbekistan mateAssistent Telegram Bot",
  "scripts": {
    "dev": "npx tsx src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "start:cluster": "pm2 start ecosystem.config.js",
    "start:cluster:dev": "pm2 start ecosystem.config.js --env development",
    "stop:cluster": "pm2 stop ecosystem.config.js",
    "reload:cluster": "pm2 reload ecosystem.config.js",
    "logs": "pm2 logs rss-bot",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/install-ytdlp.js"
  },
  "dependencies": {
    "@andresaya/edge-tts": "^1.8.0",
    "@supabase/supabase-js": "^2.105.4",
    "axios": "^1.9.0",
    "axios-cookiejar-support": "^6.0.5",
    "bullmq": "^5.76.7",
    "cheerio": "^1.2.0",
    "dotenv": "^16.6.1",
    "duck-duck-scrape": "^2.2.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "google-tts-api": "^2.0.2",
    "groq-sdk": "^0.5.0",
    "i18next": "^26.1.0",
    "ioredis": "^5.10.1",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^6.34.0",
    "tough-cookie": "^6.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.39",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "typescript": "$typescript"
  }
}
